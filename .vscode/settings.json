{
    "Lua.runtime.version": "Lua 5.4",
    "Lua.diagnostics.globals": ["print", "io", "os", "string", "math", "table"],
    "Lua.diagnostics.disable": [
        "undefined-field",
        "missing-fields"
    ],
    "code-runner.executorMap": {
        "lua": "lua main.lua"
    },
    "code-runner.runInTerminal": true,
    "code-runner.saveFileBeforeRun": true
}